# ✅ TODAS estas variables son GRATUITAS - NO REQUIEREN TARJETA DE CRÉDITO
# Este es un archivo de ejemplo - cópialo a .env.local y llena los valores

# VAPID KEYS PARA NOTIFICACIONES PUSH - COMPLETAMENTE GRATUITO
# Las keys se generan UNA sola vez localmente con:
#   npx web-push generate-vapid-keys
# 
# No requieren cuenta en ningún servicio externo
# No tienen costo alguno
# Solo pégalas aquí después de generarlas:

NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:tuemail@example.com

# URL PÚBLICA DEL SITIO - La obtienes automáticamente al desplegar en Vercel
# Ejemplo: https://mi-app-recordatorios.vercel.app
NEXT_PUBLIC_APP_URL=http://localhost:3000

# (Opcional para persistencia en producción)
# Si quieres almacenar suscripciones en Supabase crea una tabla `push_subscriptions`
# y agrega estas variables en Vercel/entorno:
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
